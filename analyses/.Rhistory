ggplot(input, aes(x = Age, fill = Diagnostic, pattern = Diagnostic)) +
geom_density_pattern(
aes(pattern_spacing = Diagnostic),
alpha = 0.5,
pattern_color = "white",      # Color de las líneas del patrón
pattern_fill = "white",       # Color de relleno del patrón (si aplica)
pattern_density = 0.1,        # Grosor del patrón
pattern_spacing = 0.02        # Espaciado entre líneas/puntos
) +
scale_fill_manual(values = c(
"BD-I" = "slateblue2",
"BD-II" = "pink",
"NO" = "darkorange",
"SZAFF" = "red",
"UNKNOWN" = "grey"
)) +
# Asignamos un patrón diferente a cada grupo
