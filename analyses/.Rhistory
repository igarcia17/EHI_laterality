"BD-I" = "stripe",
"BD-II" = "crosshatch",
"NO" = "circle",
"SZAFF" = "none",
"UNKNOWN" = "placeholder"
)) +
labs(
title = "Distribución de Edad por Diagnóstico",
x = "Edad",
y = "Densidad",
fill = "Grupo",
pattern = "Grupo"
) +
theme_minimal()
