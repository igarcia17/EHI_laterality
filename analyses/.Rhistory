Score10items >= -cutoff & Score10items <= cutoff ~ "mixed",
Score10items > cutoff ~ "right"
)
)
vars <- c("WHODAS_total32", "IcgGe", "INES", "ScoreEeag")
# n por grupo
n_groups <- data_grouped %>%
count(group)
n_groups <- setNames(n_groups$n, n_groups$group)
get_stats <- function(df, var) {
m <- mean(df[[var]], na.rm = TRUE)
s <- sd(df[[var]], na.rm = TRUE)
sprintf("%.2f (%.2f)", m, s)
}
get_wilcox_p <- function(df, var) {
df <- df %>% filter(!is.na(.data[[var]]))
p1 <- wilcox.test(df[[var]] ~ df$group %in% c("left", "mixed"))$p.value
p2 <- wilcox.test(df[[var]] ~ df$group %in% c("mixed", "right"))$p.value
p3 <- wilcox.test(df[[var]] ~ df$group %in% c("left", "right"))$p.value
# combinación simple (Fisher)
p_combined <- suppressWarnings(
sum(-2 * log(c(p1, p2, p3)))
)
# devolver p-value global Kruskal-Wallis (más correcto)
p_kw <- kruskal.test(df[[var]] ~ df$group)$p.value
return(sprintf("KW p=%.3g | W p(L-M)=%.3g, M-R=%.3g, L-R=%.3g",
p_kw, p1, p2, p3))
}
summary_table <- lapply(vars, function(v) {
stats_df <- data_grouped %>%
group_by(group) %>%
summarise(value = get_stats(cur_data(), v), .groups = "drop") %>%
pivot_wider(names_from = group, values_from = value)
pval <- get_wilcox_p(data_grouped, v)
stats_df %>%
mutate(
variable = v,
p_value = pval
) %>%
select(variable, left, mixed, right, p_value)
}) %>%
bind_rows()
colnames(summary_table) <- c(
"variable",
paste0("left (n=", n_groups["left"], ")"),
paste0("mixed (n=", n_groups["mixed"], ")"),
paste0("right (n=", n_groups["right"], ")"),
"p-value"
)
return(summary_table)
}
make_groups_summary(all_df_selection, 90)
