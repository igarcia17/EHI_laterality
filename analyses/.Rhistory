# Crear la tabla base
tabla1 <- CreateTableOne(
vars = variables,
strata = "BD_patient",
data = input,
factorVars = categoricas,
addOverall = TRUE  # Para que incluya la columna "Total"
)
# Mostrar la tabla con un formato limpio
print(tabla1,
showAllLevels = TRUE,
formatOptions = list(big.mark = ","),
nonnormal = c("Age")) # Si Age no sigue una dist. normal, usará medianas y test de Wilcoxon
# Convertir a matriz/dataframe para exportar
tabla_final <- print(tabla1, quote = FALSE, noSpaces = TRUE, printToggle = FALSE)
# Guardar como CSV (se abre perfecto en Excel)
write.csv(tabla_final, "Tabla1_Demograficos.csv")
