PRS_amb = as.numeric(PRS_amb),
PRS_BD = as.numeric(PRS_BD),
PRS_SCZ = as.numeric(PRS_SCZ)
)
sapply(input, class)
if(oldies){
input <- input %>%
filter(Oldies_dataset == "YES") %>% droplevels()
}
#Set up variables of interest
df <- input%>%
drop_na(FID)%>%
mutate(Score10items = as.numeric(Score10items))%>%
